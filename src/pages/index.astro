---
import '../styles/global.css'
import Layout from "../layouts/Layout.astro";
---

<Layout titre="Accueil">
  <section class="py-16 text-center">
    <h1 class="text-4xl font-bold text-gray-900">Trouvez la maison de vos rêves</h1>
    <p class="mt-4 text-lg text-gray-500 max-w-xl mx-auto">
      Parcourez nos offres immobilières et trouvez le bien qui vous correspond.
    </p>
    <div class="mt-8 flex justify-center gap-4">
      <a href="/offres" class="bg-blue-600 text-white px-6 py-3 rounded-xl font-medium hover:bg-blue-700 transition">
        Voir les offres
      </a>
      <a href="/agents" class="border border-gray-300 text-gray-700 px-6 py-3 rounded-xl font-medium hover:bg-gray-50 transition">
        Nos agents
      </a>
    </div>
  </section>

  <section class="grid grid-cols-1 sm:grid-cols-3 gap-6 py-8 border-t">
    <div class="text-center p-6">
      <div class="text-3xl font-bold text-blue-600">100+</div>
      <div class="mt-1 text-gray-500 text-sm">Offres disponibles</div>
    </div>
    <div class="text-center p-6">
      <div class="text-3xl font-bold text-blue-600">20+</div>
      <div class="mt-1 text-gray-500 text-sm">Agents expérimentés</div>
    </div>
    <div class="text-center p-6">
      <div class="text-3xl font-bold text-blue-600">500+</div>
      <div class="mt-1 text-gray-500 text-sm">Clients satisfaits</div>
    </div>
  </section>
</Layout>
