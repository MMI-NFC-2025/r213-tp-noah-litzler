---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import { getAgents } from "../../js/backend.mjs";

const agents = await getAgents();
---

<Layout titre="Nos agents">
  <h1 class="text-2xl font-bold text-gray-900">Nos agents</h1>
  <p class="mt-1 text-gray-500">Rencontrez notre équipe de professionnels.</p>

  <div class="mt-6">
    {agents.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {agents.map((agent) => (
          <a
            href={`/agents/${agent.id}`}
            class="flex items-center gap-4 p-4 rounded-xl border bg-white shadow-sm hover:shadow-md hover:-translate-y-0.5 transition"
          >
            <div class="w-12 h-12 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 font-bold text-lg shrink-0">
              {agent.prenom?.[0]}{agent.nom?.[0]}
            </div>
            <div>
              <div class="font-semibold text-gray-900">{agent.prenom} {agent.nom}</div>
              <div class="text-sm text-gray-400">{agent.email}</div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p class="text-gray-500">Aucun agent trouvé.</p>
    )}
  </div>
</Layout>
