---
import EvenCard from "../components/EvenCard.astro";
import Layout from "../layouts/Layout.astro";

const events = [
    {
        title: "Conférence sur les astres",
        date: "Lundi 12 Juillet",
        favori: true,
    },
    {
        title: "Atelier sur les étoiles",
        date: "Mardi 13 Juillet",
        favori: false,
    },
];
---



<Layout title="Agenda">
    <h1>Event Agenda</h1>
    {
        events.map((event) => (
            <EvenCard event=(ev) />
        ))
    }

</Layout>
